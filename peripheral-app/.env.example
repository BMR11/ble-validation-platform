# Copy this file to `.env` in this directory (never commit `.env`).
# See docs/remote-profiles.md

# Same Wi‑Fi as this machine — IPv4 only (e.g. from `ipconfig getifaddr en0` on Mac).
# Leave empty for Android emulator (uses 10.0.2.2) or iOS Simulator (127.0.0.1).
REMOTE_PROFILE_LAN_HOST=

# Optional: HTTPS tunnel origin for cellular / off-LAN (no trailing slash).
# Example: https://your-subdomain.loca.lt
REMOTE_PROFILE_TUNNEL_BASE=
