# Full v2 iOS flow in one file (manual / debugging). The v2 shell script uses split segments
# v2-ios-01..04 instead so each step prints separately.
context platform=ios
open org.reactjs.native.example.BleCentralDemo
wait 2000
click "id=central-target-nordic-lbs"
wait 500
click "id=central-scan"
wait 9500
click "label=\"Central connect My_LBS\""
wait 10000
click "id=central-led-on"
wait 3500
click "id=central-led-off"
wait 3500
