# iOS central-app: Nordic LBS target, scan, connect to My_LBS, assert initial UI.
# Peripheral must be advertising Nordic LBS (local name My_LBS).
context platform=ios
open org.reactjs.native.example.BleCentralDemo
wait 2000
click "id=central-target-nordic-lbs"
wait 500
click "id=central-scan"
wait 9500
click "label=\"Central device My_LBS\""
wait 18000
find text "Button: Released" exists
find text "Battery: 50%" exists
