# Toggle LBS button characteristic (uint8 0/1) so central should show "Button: Pressed".
# Re-open app so Android returns to foreground after iOS steps.
context platform=android
open com.bleperipheraldemo
wait 1500
scrollintoview 'id=peripheral-char-000015241212efde1523785feabcd123-switch'
click 'id=peripheral-char-000015241212efde1523785feabcd123-switch'
wait 2000
