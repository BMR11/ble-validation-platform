# Copy to automation/.env and edit. Committed defaults live here; a minimal .env can override
# only what you need (e.g. IOS_DEVICE). Shell / CI exports still win over both files.
#
# Load order: automation/.env (optional) → this file for any key still unset.
#
# App display names (Springboard / launcher labels for agent-device `open`):
CENTRAL_APP_NAME=Central App
PERIPHERAL_APP_NAME=Peripheral App
# Legacy (only used if CENTRAL_APP_NAME / PERIPHERAL_APP_NAME are unset after load):
# IOS_CENTRAL_DISPLAY_NAME=
# ANDROID_PERIPHERAL_OPEN_DISPLAY=

# --- iOS central (agent-device) ---
# Physical device name from: cd automation && npx agent-device devices --json (kind=device)
IOS_DEVICE=
# Optional: IOS_UDID=… if you must target by UDID (E2E uses --udid when IOS_DEVICE is unset)
# IOS_UDID=

# Bundle id in replay scripts (stripped before top-level open)
IOS_CENTRAL_BUNDLE_REPLAY=org.reactjs.native.example.BleCentralDemo

# agent-device iOS runner signing (physical device). Match central-app DEVELOPMENT_TEAM.
# AGENT_DEVICE_IOS_TEAM_ID=

# --- Android peripheral ---
# applicationId — debug: com.bleperipheraldemo | release APK: com.bleperipheraldemo.release
ANDROID_PERIPHERAL_PACKAGE=com.bleperipheraldemo

# Optional
# ANDROID_SERIAL=
# PERIPH_SESSION=ble-demo-peripheral
# CENT_SESSION=ble-demo-central
# SKIP_ADB_BOOTSTRAP=0
# ALLOW_IOS_SIMULATOR_UNTARGETED=0
# E2E_SKIP_EXIT_TEARDOWN=1
# E2E_IOS_OPEN_RELAUNCH=1
# V2_BROADCAST_GAP_MS=200
# V2_POST_BOOTSTRAP_MS=1500   # v2 script: wait after adb launch before AUTOMATION_* broadcasts (RN must register receiver)
# V2_VERBOSE=0                # v2 script: set to 1 to print agent-device / adb output (default: quiet step lines only)
# V2_DEBUG=0                  # v2 script: set to 1 to show benign session-close noise (e.g. SESSION_NOT_FOUND); CLI -d forces on
