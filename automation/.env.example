# Copy to automation/.env (gitignored via repo root .env rule) and adjust.
# Values here are applied only when the variable is not already set in your shell.

# iOS central target (set one or both). Prefer IOS_UDID for routing; IOS_DEVICE alone is auto-mapped
# to the physical phone's id via `agent-device devices --json` (kind=device). If that fails, set UDID:
IOS_DEVICE=iPhone-RG
# IOS_UDID=00008140-001A109402...

# Get UDID + exact name:  cd automation && npx agent-device devices --json

# Android peripheral applicationId — debug / local: com.bleperipheraldemo | release APK: com.bleperipheraldemo.release
ANDROID_PERIPHERAL_PACKAGE=com.bleperipheraldemo

# Optional
# ANDROID_SERIAL=
# PERIPH_SESSION=ble-demo-peripheral
# CENT_SESSION=ble-demo-central
# SKIP_ADB_BOOTSTRAP=0
# ALLOW_IOS_SIMULATOR_UNTARGETED=0
