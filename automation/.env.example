# Copy to automation/.env (gitignored via repo root .env rule) and adjust.
# Values here are applied only when the variable is not already set in your shell.

# iOS central: set IOS_DEVICE to the exact name from `agent-device devices --json` (kind=device).
# E2E passes `--device` (same pattern as: agent-device open "BleCentralDemo" --platform ios --device "…").
IOS_DEVICE=iPhone-RG
# Optional: IOS_UDID=… only if you must target by UDID (when set without IOS_DEVICE, E2E uses --udid).

# iOS central `agent-device open` display name (matches Springboard label; default BleCentralDemo).
# IOS_CENTRAL_DISPLAY_NAME=BleCentralDemo
# Bundle id in replays’ `open …` line — script strips it and opens via display name above.
# IOS_CENTRAL_BUNDLE_REPLAY=org.reactjs.native.example.BleCentralDemo

# Get UDID + exact name:  cd automation && npx agent-device devices --json

# agent-device iOS runner signing (physical device replay). Match central-app/ios DEVELOPMENT_TEAM or your Apple Membership Team ID.
# AGENT_DEVICE_IOS_TEAM_ID=8H8Y4C2SQ8

# Android peripheral applicationId — debug / local: com.bleperipheraldemo | release APK: com.bleperipheraldemo.release
ANDROID_PERIPHERAL_PACKAGE=com.bleperipheraldemo

# Optional
# ANDROID_SERIAL=
# PERIPH_SESSION=ble-demo-peripheral
# CENT_SESSION=ble-demo-central
# SKIP_ADB_BOOTSTRAP=0
# ALLOW_IOS_SIMULATOR_UNTARGETED=0
# E2E_SKIP_EXIT_TEARDOWN=1   # debug: do not close sessions / force-stop on abort (success path still runs step 7)
# E2E_IOS_OPEN_RELAUNCH=1    # open --relaunch (hard iOS restart); default 0 — terminate can fail on some devices
